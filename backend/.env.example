# =============================================================================
# SplitEx Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# ─── DATABASE ───────────────────────────────────────────────────────────────
# Railway MySQL connection string (free tier)
# Get this from: railway.app → Your Project → MySQL → Connect → Copy connection URL
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@containers-xx.railway.app:6543/railway"

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change-me-to-a-strong-random-64-char-secret-for-access-tokens"
JWT_REFRESH_SECRET="change-me-to-a-different-strong-random-64-char-secret-for-refresh"

# ─── SERVER ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ───────────────────────────────────────────────────────────────────
# URL of the frontend (Vite dev server or Vercel deployment)
FRONTEND_URL=http://localhost:5173

# ─── PRODUCTION ONLY ────────────────────────────────────────────────────────
# Set these in Render dashboard environment variables
# FRONTEND_URL=https://your-app.vercel.app
# NODE_ENV=production
