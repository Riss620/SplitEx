# =============================================================================
# SplitEx Frontend — Environment Variables
# Copy this file to .env.local for local development.
# For Vercel production: add these in the Vercel project dashboard → Settings → Environment Variables
# =============================================================================

# ─── Backend API URL ─────────────────────────────────────────────────────────
# Local development (Vite dev server proxies to the Express backend)
VITE_API_URL=http://localhost:3001/api

# Production (set this in Vercel dashboard to your Render backend URL)
# VITE_API_URL=https://splitex-api.onrender.com/api
